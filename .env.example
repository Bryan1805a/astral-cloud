# Database Configuration
# Copy this file to .env and fill in your actual values
DB_NAME=enter_your_db_name_here
DB_USER=enter_your_user_name_here
DB_PASS=enter_your_password_here
DB_ROOT_PASS=enter_your_root_password_here

# Application URL
APP_URL=http://localhost:8080

# SMTP Configuration (for registration verification emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_ENCRYPTION=smtps
SMTP_FROM_EMAIL=noreply@astralcloud.com
SMTP_FROM_NAME=Astral Cloud

# VNPay Payment Gateway (Sandbox)
# Get your credentials at https://sandbox.vnpayment.vn
VNP_TMN_CODE=YOUR_TERMINAL_ID
VNP_HASH_SECRET=YOUR_SECRET_KEY
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:8080/payment/vnpay-return

# VM Bridge (VMware Workstation provisioning)
# Docker → Windows host uses host.docker.internal; bare metal → localhost
VM_BRIDGE_URL=http://host.docker.internal:10001

# Base VM root password (the password your Ubuntu_Base VM currently has)
# Used by vmrun to inject the generated password into newly cloned VMs
VM_BASE_PASSWORD=password

# ttyd Web Terminal (browser-based SSH console)
# External URL where the VM Bridge (port 10001) is reachable from the browser.
# ttyd proxies through the VM Bridge at /console/{serviceId}/
# Leave empty to auto-derive from APP_URL host + port 10001.
# For ngrok: create a second tunnel (ngrok http 10001) and put the URL here.
TTYD_EXTERNAL_URL=

