# VM Bridge — VMware provisioning + web SSH console
# Copy this file to .env and edit the paths below

# Path to vmrun.exe (default: VMware Workstation default install)
VMRUN_PATH="C:\Program Files\VMware\VMware Workstation\vmrun.exe"

# Path to your base Ubuntu VM template (.vmx file)
BASE_VMX=C:\Users\Bryan\Documents\Virtual Machines\Ubuntu_Base\Ubuntu_Base.vmx

# Directory where cloned VMs will be stored
VM_DIR=C:\Users\Bryan\Documents\VMs

# Port the bridge listens on (default: 10001)
PORT=10001
